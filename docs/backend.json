
{
  "entities": {
    "AppSettings": {
      "title": "App Settings",
      "description": "User preferences and system-wide settings.",
      "type": "object",
      "properties": {
        "vibration": { "type": "boolean", "description": "Whether haptic feedback is enabled." },
        "fineRate": { "type": "number", "description": "Rate charged per absence." },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "The UI theme preference." }
      },
      "required": ["vibration", "fineRate", "theme"]
    },
    "Class": {
      "title": "Class",
      "description": "A student group or section.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the class." },
        "onDays": { "type": "array", "items": { "type": "string" }, "description": "List of dates (YYYY-MM-DD) marked as class days." }
      },
      "required": ["name", "onDays"]
    },
    "Student": {
      "title": "Student",
      "description": "A student profile within a class.",
      "type": "object",
      "properties": {
        "roll": { "type": "number", "description": "Student roll number." },
        "attendance": { "type": "object", "description": "Mapping of date strings to 'present' or 'absent'." }
      },
      "required": ["roll", "attendance"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}/settings": {
      "schema": "#/entities/AppSettings",
      "description": "Individual user settings."
    },
    "/users/{userId}/classes/{classId}": {
      "schema": "#/entities/Class",
      "description": "Classes created by the user."
    },
    "/users/{userId}/classes/{classId}/students/{studentId}": {
      "schema": "#/entities/Student",
      "description": "Students belonging to a specific class."
    }
  }
}
